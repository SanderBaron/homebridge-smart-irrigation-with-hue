{
  "name": "homebridge-weather-smart-irrigation",
  "displayName": "Smart Irrigation",
  "version": "0.1.0",
  "description": "Weather-aware, fully configurable Homebridge irrigation platform driving Philips Hue smart sockets.",
  "license": "MIT",
  "author": "Sander Baron",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SanderBaron/homebridge-weather-smart-irrigation.git"
  },
  "bugs": {
    "url": "https://github.com/SanderBaron/homebridge-weather-smart-irrigation/issues"
  },
  "homepage": "https://github.com/SanderBaron/homebridge-weather-smart-irrigation#readme",
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "irrigation",
    "sprinkler",
    "weather",
    "hue",
    "philips-hue",
    "smart-garden",
    "open-meteo",
    "buienradar"
  ],
  "engines": {
    "node": "^22 || ^24",
    "homebridge": "^2.0.0"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.0.0",
    "bonjour-service": "^1.2.1",
    "undici": "^7.26.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "homebridge": "^2.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.4",
    "typescript": "^5.5.4"
  }
}
